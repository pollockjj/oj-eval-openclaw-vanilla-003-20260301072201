ADDTEAM TeamA
ADDTEAM TeamB
START DURATION 100 PROBLEM 2
SUBMIT A BY TeamA WITH Accepted AT 10
SUBMIT A BY TeamB WITH Wrong_Answer AT 15
SUBMIT A BY TeamB WITH Accepted AT 20
SUBMIT B BY TeamA WITH Runtime_Error AT 25
QUERY_SUBMISSION TeamA WHERE PROBLEM=A AND STATUS=ALL
QUERY_SUBMISSION TeamA WHERE PROBLEM=ALL AND STATUS=Accepted
QUERY_SUBMISSION TeamB WHERE PROBLEM=A AND STATUS=Wrong_Answer
QUERY_SUBMISSION TeamB WHERE PROBLEM=ALL AND STATUS=ALL
END
